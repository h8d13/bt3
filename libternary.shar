#ifndef _LIBTER9_H
#include "libter9.h"
#endif

#ifndef _LIBTER9IO_H
#define _LIBTER9IO_H

#include <stdio.h>
#include "libter9.h"

/* Input/Output */

void puthept_ter9( uter9_t n, FILE *f );
void putdec_uter9( uter9_t n, FILE *f );
void putdec_bter9( bter9_t n, FILE *f );

